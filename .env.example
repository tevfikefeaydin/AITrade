# AITrade Environment Variables
# Bu dosyayı .env olarak kopyala ve değerleri doldur

# ========================================
# API KEYS - ASLA COMMIT ETME!
# ========================================

# Binance
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# Diğer Exchange'ler (opsiyonel)
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# ========================================
# DATABASE
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/aitrade
REDIS_URL=redis://localhost:6379/0

# ========================================
# API SETTINGS
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ========================================
# TRADING SETTINGS
# ========================================
DEFAULT_TIMEFRAME=1h
RISK_PER_TRADE=0.02
MIN_RISK_REWARD=2.0
SIGNAL_CONFIDENCE_THRESHOLD=0.7

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=INFO
LOG_FILE=logs/aitrade.log

# ========================================
# ML MODEL
# ========================================
MODEL_PATH=models/xgboost_v1.pkl
RETRAIN_INTERVAL_DAYS=7
