# AITrade .gitignore

# ========================================
# Python
# ========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv/

# ========================================
# IDE
# ========================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ========================================
# Environment & Secrets
# ========================================
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ========================================
# Logs
# ========================================
logs/
*.log
npm-debug.log*

# ========================================
# Testing
# ========================================
.coverage
htmlcov/
.tox/
.pytest_cache/
.mypy_cache/

# ========================================
# ML Models (büyük dosyalar)
# ========================================
models/*.pkl
models/*.h5
models/*.pt
!models/.gitkeep

# ========================================
# Data
# ========================================
data/*.csv
data/*.parquet
data/*.json
!data/.gitkeep

# ========================================
# OS
# ========================================
.DS_Store
Thumbs.db
desktop.ini

# ========================================
# Node (frontend için)
# ========================================
node_modules/
.next/
out/
.nuxt/

# ========================================
# Misc
# ========================================
*.bak
*.tmp
*.temp
.cache/
